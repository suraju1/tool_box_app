rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEBUG RULES: Allow any authenticated user (anonymous or regular) to read/write all documents.
    // This ignores the mismatch between Firebase UID and Backend User ID.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
